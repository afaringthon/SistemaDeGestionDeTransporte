<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<BorderPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@application.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gestiontransporte.sistemadegestiondetransporte.ui.MainController">

    <top>
        <HBox spacing="8" style="-fx-padding: 10; -fx-background-color: #1e1e2e;">
            <children>
                <ComboBox fx:id="comboCalcOrigen" promptText="Origen" prefWidth="160" />
                <ComboBox fx:id="comboCalcDestino" promptText="Destino" prefWidth="160" />
                <ComboBox fx:id="comboCriterio" promptText="Criterio" prefWidth="120" />
                <ComboBox fx:id="comboAlgoritmo" promptText="Algoritmo" prefWidth="140" />
                <ComboBox fx:id="comboVehiculo" promptText="Vehículo" prefWidth="120" />
                <Button fx:id="btnBuscarRuta" text="Buscar Ruta" onAction="#onBuscarRuta" />
                <Button fx:id="btnVerAlternativa" text="Ver Ruta Alternativa" onAction="#onVerAlternativa" />
                <Separator orientation="VERTICAL" />
                <Button fx:id="btnAgregarParada" text="Agregar Parada" onAction="#onAgregarParada" />
                <Button fx:id="btnAgregarRuta" text="Agregar Ruta" onAction="#onAgregarRuta" />
                <Button fx:id="btnGuardarGrafo" text="Guardar" onAction="#onGuardarGrafo" />
            </children>
        </HBox>
    </top>

    <center>
        <AnchorPane fx:id="graphContainer" />
    </center>

    <right>
        <VBox prefWidth="260" spacing="8" style="-fx-padding: 12; -fx-background-color: #f5f5f5;">
            <children>
                <Label text="Ruta principal:" />
                <Label fx:id="labelRutaPrincipal" text="-" wrapText="true" />
                <Label fx:id="labelValorPrincipal" text="-" />
                <Separator />
                <Label text="Ruta alternativa:" />
                <Label fx:id="labelRutaAlternativa" text="-" wrapText="true" />
                <Label fx:id="labelValorAlternativo" text="-" />
                <Separator />
                <Label text="Parada seleccionada:" />
                <Label fx:id="labelParadaSeleccionada" text="-" />
                <Button fx:id="btnModificarParada" text="Modificar Parada" onAction="#onModificarParada" />
                <Button fx:id="btnEliminarParada" text="Eliminar Parada" onAction="#onRemoverParada" />
                <Separator />
                <Label text="Ruta seleccionada:" />
                <Label fx:id="labelRutaSeleccionada" text="-" wrapText="true" />
                <Button fx:id="btnModificarRuta" text="Modificar Ruta" onAction="#onEditarRuta" />
                <Button fx:id="btnEliminarRuta" text="Eliminar Ruta" onAction="#onRemoverRuta" />
            </children>
        </VBox>
    </right>

    <bottom>
        <Label fx:id="statusLabel" text="Estado: Listo" style="-fx-padding: 6;" />
    </bottom>

</BorderPane>

